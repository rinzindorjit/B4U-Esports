{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/css/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/js/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/**/*.png",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/**/*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/**/*.jpeg",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/**/*.gif",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/**/*.svg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
